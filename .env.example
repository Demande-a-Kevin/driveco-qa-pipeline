# ============================================================
# DRIVECO QA PIPELINE — Variables d'environnement
# Copier ce fichier en .env puis remplacer chaque placeholder.
# Les IDs internes (Cloudflare, Notion, Slack) ne sont pas des secrets au sens strict,
# mais on évite de les hardcoder pour garder un repo portable et propre.
# ============================================================

# ── Cloudflare Worker / D1 ───────────────────────────────────
# Obligatoire pour les endpoints appelés par le pipeline Python.
# CF_API_TOKEN est conservé pour compatibilité documentaire, mais le code Python
# actuel n'utilise que CF_WORKER_URL et CF_WORKER_AUTH.
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_D1_DATABASE_ID=your_d1_database_id
CF_API_TOKEN=optional_cloudflare_api_token_if_needed_else_blank
CF_WORKER_URL=https://airall-webhook.SUBDOMAIN.workers.dev
# Basic auth = base64("AIRCALL_API_ID:AIRCALL_API_TOKEN")
CF_WORKER_AUTH=Basic REPLACE_WITH_BASE64_BASIC_AUTH

# ── Aircall ──────────────────────────────────────────────────
AIRCALL_API_ID=your_aircall_api_id
AIRCALL_API_TOKEN=your_aircall_api_token
AIRCALL_ASSISTANCE_LINE_ID=785174
AIRCALL_MAINTENANCE_LINE_ID=785175
AIRCALL_UCC_TRANSFER_LINE_ID=1214611

# ── Anthropic (Claude) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Notion ───────────────────────────────────────────────────
NOTION_API_KEY=secret_REPLACE_ME
NOTION_KB_PAGE_ID=replace_with_notion_kb_page_id
NOTION_REPORTS_PAGE_ID=replace_with_notion_reports_page_id

# ── Slack ────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_CHANNEL_ID=replace_with_slack_channel_id
SLACK_VOC_ALERTS_CHANNEL_ID=replace_with_voc_alerts_channel_id

# ── Supabase (Lot 2 dashboard storage) ───────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...
SUPABASE_DASHBOARD_ANON_KEY=eyJhbGciOi...
SUPABASE_TIMEOUT_SECONDS=20

# ── Voice of Customer (Lot 6) ────────────────────────────────
ENABLE_VOC_ANALYSIS=true
VOC_VERBATIM_RETENTION_DAYS=180
VOC_MIN_WEAK_SIGNAL_COUNT=3
ENABLE_CLAUDE_SHADOW=false
CLAUDE_SHADOW_SAMPLE_PCT=0.10
RELIABILITY_MAE_ALERT_THRESHOLD=1.0
HEALTH_PORT=8788
RUN_DEGRADED_THRESHOLD=0.5

# ── Outputs locaux ───────────────────────────────────────────
# Laisse vide pour utiliser le défaut repo-local : ./qa-driveco-data
REPORT_OUTPUT_DIR=
LOG_DIR=
NOTION_CACHE_PATH=

# ── Google Drive (optionnel) ─────────────────────────────────
GDRIVE_FOLDER_ID=
GDRIVE_CREDENTIALS_FILE=/absolute/path/to/gdrive_credentials.json
GDRIVE_TOKEN_FILE=/absolute/path/to/gdrive_token.json

# ── Ollama (optionnel, fallback sur Claude si indisponible) ─
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_FIXED_MODEL=gemma4:latest
OLLAMA_MODEL_SCREENING=gemma4:latest
OLLAMA_MODEL_ANALYSIS=gemma4:latest
OLLAMA_TIMEOUT=60
OLLAMA_ANALYSIS_TIMEOUT=3600
OLLAMA_PRESCREEN_TIMEOUT=180
OLLAMA_PRESCREEN_BATCH_SIZE=4
OLLAMA_TRANSCRIPT_MAX_CHARS=3600
OLLAMA_NUM_CTX=32768
OLLAMA_TEMPERATURE=0.2
OLLAMA_TOP_P=0.95
OLLAMA_TOP_K=64
OLLAMA_RISK_THRESHOLD=4.0
HAIKU_REEVAL_THRESHOLD=7.0
